# このファイルはテンプレートです。実際のAPIキーを記入しないでください。
# コピーして .env を作成し、そこにキーを設定してください。
#   cp .env.example .env

# Reddit API
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ai-trend-analyzer/0.1

# Qiita API
QIITA_ACCESS_TOKEN=

# DBパス（デフォルト: data/trends.db）
DB_PATH=data/trends.db

# LLM Provider（zhipu / anthropic / openai）
LLM_PROVIDER=zhipu
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=glm-4-flash
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3
